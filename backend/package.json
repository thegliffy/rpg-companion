{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json && cp -r src/db/migrations dist/db/migrations",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "shared": "*",
    "express": "^5.2.1",
    "express-session": "^1.18.1",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.45.2",
    "bcrypt": "^6.0.0",
    "socket.io": "^4.8.1",
    "@dice-roller/rpg-dice-roller": "^5.5.1",
    "multer": "^2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "drizzle-kit": "^0.31.10",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.9.0"
  }
}
